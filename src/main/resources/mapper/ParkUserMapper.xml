<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.syan.smart_park.dao.ParkUserMapper">

    <!-- 根据openid查询用户 -->
    <select id="selectByOpenid" resultType="com.syan.smart_park.entity.ParkUser">
        SELECT *
        FROM park_user
        WHERE openid = #{openid}
          AND deleted = 0
    </select>

    <!-- 根据手机号查询用户 -->
    <select id="selectByPhone" resultType="com.syan.smart_park.entity.ParkUser">
        SELECT *
        FROM park_user
        WHERE phone = #{phone}
          AND deleted = 0
    </select>

</mapper>
